Project FWG_Adaptive_Assessments {
  database_type: 'PostgreSQL'
}

/********************************************************
 * 1) People & Consent
 ********************************************************/
Table "user" {
  id           serial [pk]
  created_at   timestamptz [default: `now()`]
}

Table profile {
  id             serial [pk]
  user_id        int [ref: > user.id]
  sex_at_birth   text
  birth_year     int
}

Table consent {
  id         serial [pk]
  user_id    int [ref: > user.id]
  version    text
  signed_at  timestamptz
}

/********************************************************
 * 2) Question Bank (versioned)
 ********************************************************/

Enum answer_kind {
  NUMERIC
  SCALE
}

Table unit {
  id        serial [pk]
  code      text   // e.g., "kg", "cm", "min", "hr"
  name      text   // e.g., "kilogram", "centimeter", "minute"
  Note: 'Normalised units for numeric answers'
}

Table scale {
  id        serial [pk]
  min_value int    // e.g., 0
  max_value int    // e.g., 3 or 5 or 10
  labels    jsonb  // optional: { "0":"Not at all", "1":"Several days", ... }
  reversed  boolean [default: false] // if higher=better and you need reverse scoring
  Note: 'Normalised scale definitions'
}

Table questionnaire {
  id     serial [pk]
  name   text
  domain text // consider Enum later: 'mental' | 'diet' | 'physical_activity' | 'women_health'
  Note:  'Question Topic'
}


Table question {
  id                serial [pk]                // fixed identity for this “item”
  questionnaire_id  int   [ref: > questionnaire.id]
  text              text                       // the prompt shown to the user
  explanation       text                       // help text / tooltip
  required          boolean
  // answer model
  answer_kind       answer_kind                 // NUMERIC or SCALE
  // For NUMERIC
  unit_id           int   [ref: > unit.id]      // required iff answer_kind=NUMERIC
  min_numeric       numeric                      // nullable; e.g., 0
  max_numeric       numeric                      // nullable; e.g., 300
  precision_dp      int                          // decimal places allowed; e.g., 0,1,2
  period_question   boolean
  scale_id          int   [ref: > scale.id]      // answer_kind=SCALE

  Note: 'Exactly one of {unit_id|min_numeric|max_numeric|precision_dp} or {scale_id} is used based on answer_kind'
}

/********************************************************
 * 3) Scheduling / Rotation
 ********************************************************/
Table schedule {
  id         serial [pk]
  frequency  text // 'monthly' | 'yearly'
  Note:       'Not sure how to intergrate with ML so far'
}

Table question_schedule {
  id             serial [pk]
  schedule_id    int [ref: > schedule.id]
  question_id    int [ref: > question.id]
  rotation_group text // nullable e.g., 'setA','setB'
  Note:       'Not sure how to intergrate with ML so far'
}

/********************************************************
 * 4) Branching Rules. --> Do we need to store that information?
 ********************************************************/
Table rule {
  id                           serial [pk]
  name                         text
  trigger_question_version_id  int [ref: > question.id]
  expression                   jsonb // {"op":">=","question":"Q1a","value":2}
  target_action                jsonb // {"show":[101,102],"hide":[103],"route":"groupB"}
  Note:                       'Do we need to store that information?'
}

/********************************************************
 * 5) Session & Responses
 ********************************************************/
Table session {
  id           serial [pk]
  user_id      int [ref: > user.id]
  period_month int // July
  period_year  int // 2025
  started_at   timestamptz [default: `now()`]
  completed_at timestamptz
  Note: 'One adaptive run per session.'
}

Table response {
  id                   serial [pk]
  session_id           int [ref: > session.id]
  question_version_id  int [ref: > question.id]
  created_at           timestamptz [default: `now()`]
  value_number         numeric   
  value_scale          int       
  raw                  jsonb   // multi-select as JSON array
  score                numeric // nullable; computed for PHQ/GAD etc.
}

/********************************************************
 * 6) Risk & Actions
 ********************************************************/
Table flag {
  id         serial [pk]
  user_id    int [ref: > user.id]
  session_id int [ref: > session.id]
  domain     text // 'mental' | 'diet' | 'activity' | 'women_health'
  level      text // 'none' | 'mild' | 'moderate' | 'high'
  details    jsonb
  created_at timestamptz [default: `now()`]
}

